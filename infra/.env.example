# Copy to infra/.env before `docker compose up` (never commit infra/.env).
# docker compose -f infra/docker-compose.yml --env-file infra/.env up --build

# Required — use a long random value in any shared or production-like environment
JWT_SECRET=replace-with-a-long-random-secret

# Optional JWT lifetime (default 1d)
JWT_EXPIRES_IN=1d

# Browser origins allowed by backend + appointment-service CORS
CORS_ORIGINS=http://localhost:3000

# Frontend Vite URLs — baked into the image at build time (not runtime env)
# Use host-reachable URLs so the browser can call the APIs
VITE_API_URL=http://localhost:5000
VITE_APPOINTMENT_URL=http://localhost:5001

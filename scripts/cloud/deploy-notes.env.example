# Copy values into provider dashboards / CLI — do not commit a filled copy.
# Used as a checklist for Phase 13 cloud deploy.

JWT_SECRET=
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/healthcare?retryWrites=true&w=majority

# After appointment Vercel deploy:
APPOINTMENT_SERVICE_URL=https://YOUR-APPOINTMENT.vercel.app

# After Netlify deploy:
CORS_ORIGINS=https://YOUR-SITE.netlify.app

# Netlify build env:
VITE_API_URL=https://YOUR-BACKEND.vercel.app
VITE_APPOINTMENT_URL=https://YOUR-APPOINTMENT.vercel.app

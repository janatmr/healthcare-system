# Appointment microservice — copy to .env and adjust values
PORT=5001
NODE_ENV=development

# JWT — must match backend JWT_SECRET for token validation
JWT_SECRET=replace-with-a-long-random-secret

# Docker Compose: use the mongodb service name (not localhost)
MONGODB_URI=mongodb://mongodb:27017/healthcare

# Local (outside Docker): mongodb://localhost:27017/healthcare
# MONGODB_URI=mongodb://localhost:27017/healthcare

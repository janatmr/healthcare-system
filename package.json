{
  "name": "healthcare-system",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Hospital Management System monorepo",
  "workspaces": [
    "backend",
    "frontend",
    "microservices/appointment-service"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev --workspace=backend",
    "start:backend": "npm run start --workspace=backend",
    "dev:appointment": "npm run dev --workspace=appointment-service",
    "start:appointment": "npm run start --workspace=appointment-service",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "seed": "npm run seed --workspace=backend",
    "test": "npm test --workspace=backend && npm test --workspace=appointment-service",
    "test:unit": "npm run test:unit --workspace=backend && npm run test:unit --workspace=appointment-service",
    "test:integration": "npm run test:integration --workspace=backend && npm run test:integration --workspace=appointment-service",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "docker:up": "docker compose -f infra/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.1",
    "mongodb-memory-server": "^10.1.2",
    "puppeteer": "^23.11.1"
  },
  "engines": {
    "node": ">=20"
  }
}

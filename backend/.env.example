# Backend API — copy to .env and adjust values
PORT=5000
NODE_ENV=development

# JWT — use a long random secret in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# Local (outside Docker)
MONGODB_URI=mongodb://localhost:27017/healthcare

# Docker Compose (inside containers): use the mongodb service name
# MONGODB_URI=mongodb://mongodb:27017/healthcare

# Appointment microservice URL (Docker service discovery)
APPOINTMENT_SERVICE_URL=http://appointment-service:5001

# Local (outside Docker): http://localhost:5001
# APPOINTMENT_SERVICE_URL=http://localhost:5001

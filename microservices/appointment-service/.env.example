# Appointment microservice — copy to .env and adjust values
PORT=5001
NODE_ENV=development

# Must match backend JWT_SECRET so tokens from /auth/login validate here
JWT_SECRET=replace-with-a-long-random-secret

# Local (outside Docker)
MONGODB_URI=mongodb://localhost:27017/healthcare

# Docker Compose (inside containers)
# MONGODB_URI=mongodb://mongodb:27017/healthcare

# Spec allowlist — frontend origin only
CORS_ORIGINS=http://localhost:3000

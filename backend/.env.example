# Backend API — copy to .env and adjust values
PORT=5000
NODE_ENV=development

# JWT — use a long random secret in production (must match appointment-service)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# Local (outside Docker)
MONGODB_URI=mongodb://localhost:27017/healthcare

# Docker Compose (inside containers): use the mongodb service name
# MONGODB_URI=mongodb://mongodb:27017/healthcare

# MongoDB Atlas (cloud production)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/healthcare?retryWrites=true&w=majority

# Local (outside Docker)
APPOINTMENT_SERVICE_URL=http://localhost:5001

# Docker Compose (inside containers)
# APPOINTMENT_SERVICE_URL=http://appointment-service:5001

# Cloud (Vercel appointment project URL, no trailing slash)
# APPOINTMENT_SERVICE_URL=https://healthcare-appointment.vercel.app

# Comma-separated browser origins allowed by CORS
CORS_ORIGINS=http://localhost:3000

# Cloud — Netlify site origin (and preview URLs if needed)
# CORS_ORIGINS=https://your-site.netlify.app
